# {{ project_name }} Environment Configuration

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS
CORS_ORIGINS=["*"]

{% if db_type -%}
# Database
DATABASE_URL={% if db_type == 'postgres' %}postgresql+asyncpg://user:password@localhost/{{ project_name }}{% elif db_type == 'mysql' %}mysql+aiomysql://user:password@localhost/{{ project_name }}{% else %}sqlite+aiosqlite:///./{{ project_name }}.db{% endif %}
DATABASE_ECHO=false
{% endif %}

{% if use_redis -%}
# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_ENCODING=utf-8
{% endif %}

{% if auth_type == 'jwt' -%}
# JWT Authentication
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
{% endif %}

{% if auth_type == 'session' -%}
# Session Authentication
SECRET_KEY=change-this-secret-key-in-production
SESSION_COOKIE_NAME=session
SESSION_MAX_AGE=3600
{% endif %}
